<launch>
  <param name="robot_description" command="$(find xacro)/xacro '$(find robocoaster_description)/urdf/robocoaster.xacro'" />

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
  </include>

  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model" args="-param robot_description -urdf -model robocoaster" />
</launch>
