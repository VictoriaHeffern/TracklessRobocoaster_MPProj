<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robocoaster">

   <!-- macro files for the robot links/joints -->
  <xacro:include filename="$(find kuka_kr560_desc)/urdf/kr560_r3100_2_macro.xacro"/>
  <xacro:include filename="$(find kuka_kr560_desc)/urdf/kr_fortec_ros2_control.xacro"/>
  <xacro:include filename="$(find kuka_kr560_desc)/urdf/kr_fortec_transmission.xacro"/>

  <link name="base_footprint"/>

  <joint name="base_footprint_to_chassis" type="fixed">
    <parent link="base_footprint"/>
    <child link="agv_chassis"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
  </joint>

  <link name="agv_chassis">
    <visual>
      <geometry><box size="3.5 2.2 0.5"/></geometry>
      <material name="dark_grey"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><box size="3.5 2.2 0.5"/></geometry>
    </collision>
    <inertial>
      <mass value="500"/>
      <inertia ixx="30" ixy="0" ixz="0" iyy="70" iyz="0" izz="80"/>
    </inertial>
  </link>

  <gazebo>
  <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
    <updateRate>100</updateRate>
    <leftJoint>left_wheel_joint</leftJoint>
    <rightJoint>right_wheel_joint</rightJoint>
    <wheelSeparation>2.4</wheelSeparation>
    <wheelDiameter>0.6</wheelDiameter>
    <wheelAcceleration>1.0</wheelAcceleration>
    <wheelTorque>3000</wheelTorque> <commandTopic>cmd_vel</commandTopic>
    <odometryTopic>odom</odometryTopic>
    <odometryFrame>odom</odometryFrame>
    <robotBaseFrame>base_footprint</robotBaseFrame>
    <publishWheelTF>true</publishWheelTF>
    <publishWheelJointState>true</publishWheelJointState> </plugin>
  </gazebo>

  <xacro:macro name="drive_wheel" params="prefix y_pos">
    <link name="${prefix}_wheel">
      <visual>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder length="0.2" radius="0.3"/></geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder length="0.2" radius="0.3"/></geometry>
      </collision>
      <inertial>
        <mass value="20"/>
        <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.9"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="agv_chassis"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="1.0 ${y_pos} -0.1" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left" y_pos="1.2"/>
  <xacro:drive_wheel prefix="right" y_pos="-1.2"/>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.3"/></geometry>
    </visual>
    <collision>
      <geometry><sphere radius="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="agv_chassis"/>
    <child link="caster_wheel"/>
    <origin xyz="-1.5 0 -0.1" rpy="0 0 0"/>
  </joint>

  <xacro:kuka_kr560_r3100_2_robot prefix="">
  <origin xyz="0 0 0.25" rpy="0 0 0"/> 
  </xacro:kuka_kr560_r3100_2_robot>

  <xacro:kuka_fortec_transmission prefix=""/>
  <!--
  <joint name="chassis_to_robot" type="fixed">
    <parent link="agv_chassis"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>
  -->

  <link name="gondola">
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry><box size="0.7 1.8 0.2"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
  </link>

  <joint name="tool0_to_gondola" type="fixed">
    <parent link="tool0"/>
    <child link="gondola"/>
    <origin xyz="0 0 0" rpy="0 -1.5708 0"/>
  </joint>

  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/</robotNamespace>
    </plugin>
  </gazebo>

  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="agv_chassis"/>
    <child link="lidar_link"/>
    <origin xyz="1.75 0 0.3" rpy="0 0 0"/>
  </joint>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="head_hokuyo_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <!--
            <set the lidar range here, current at like 85*>
            -->
            <min_angle>-1.48353</min_angle> <max_angle>1.48353</max_angle> 
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_head_hokuyo_controller" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>